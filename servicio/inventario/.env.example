# Production profile for docker-compose
SPRING_PROFILES_ACTIVE=prod
CONFIG_SERVER_URL=http://config-server:7071

# MySQL container/app credentials
INVENTARIO_MYSQL_ROOT_PASSWORD=root
INVENTARIO_MYSQL_DATABASE=db_inventario

# Spring datasource (used by inventario)
INVENTARIO_DB_HOST=mysql-inventario
INVENTARIO_DB_PORT=3306
INVENTARIO_DB_NAME=db_inventario
INVENTARIO_DB_USERNAME=root
INVENTARIO_DB_PASSWORD=root