# Variables de entorno para favoritos-ms
# Copiar a .env y ajustar los valores

SPRING_PROFILES_ACTIVE=prod
CONFIG_SERVER_URL=http://config-server:8888

# Base de datos PostgreSQL
DB_NAME=favoritos_db
DB_USER=favoritos_user
DB_PASS=favoritos_db_secure_2024

# JWT Secret (mismo que en auth-ms)
JWT_SECRET=<pega_aqui_el_jwt_secret_de_auth_ms>
