# Production profile for docker-compose
SPRING_PROFILES_ACTIVE=prod
CONFIG_SERVER_URL=http://config-server:7071

# MySQL container/app credentials
PAGOS_MYSQL_ROOT_PASSWORD=root
PAGOS_MYSQL_DATABASE=db_pagos

# Spring datasource (used by pagos)
PAGOS_DB_HOST=mysql-pagos
PAGOS_DB_PORT=3306
PAGOS_DB_NAME=db_pagos
PAGOS_DB_USERNAME=root
PAGOS_DB_PASSWORD=root