# .env para el perfil prod

# Perfil de Spring Boot usado por el contenedor pago-ms
SPRING_PROFILES_ACTIVE=prod

# Config Server de la plataforma
CONFIG_SERVER_URL=http://ecom-config:8888

# Bootstrap server de Kafka usado por la aplicacion
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Variables consumidas por la aplicacion: pago-ms
DB_NAME=ecom_pago_db
DB_USER=ecom
DB_PASS=ecom

# Mercado Pago Checkout Pro (no versionar valores reales)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_NOTIFICATION_URL=https://tu-dominio-publico/api/v1/pagos/mercadopago/webhook
MP_SUCCESS_URL=https://tu-frontend/payment-result?status=success
MP_FAILURE_URL=https://tu-frontend/payment-result?status=failure
MP_PENDING_URL=https://tu-frontend/payment-result?status=pending
