# .env para el perfil prod

# Perfil de Spring Boot usado por el contenedor pago-ms
SPRING_PROFILES_ACTIVE=prod

# Config Server de la plataforma
CONFIG_SERVER_URL=http://ecom-config:8888

# Bootstrap server de Kafka usado por la aplicacion
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Variables consumidas por la aplicacion: pago-ms
DB_NAME=ecom_pago_db
DB_USER=ecom
DB_PASS=ecom
