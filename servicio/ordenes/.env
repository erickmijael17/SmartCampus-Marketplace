# Production profile for docker-compose
SPRING_PROFILES_ACTIVE=prod
CONFIG_SERVER_URL=http://config-server:7071

# MySQL container/app credentials
ORDENES_MYSQL_ROOT_PASSWORD=root
ORDENES_MYSQL_DATABASE=db_ordenes

# Spring datasource (used by ordenes)
ORDENES_DB_HOST=mysql-ordenes
ORDENES_DB_PORT=3306
ORDENES_DB_NAME=db_ordenes
ORDENES_DB_USERNAME=root
ORDENES_DB_PASSWORD=root