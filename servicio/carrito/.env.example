# Production profile for docker-compose
SPRING_PROFILES_ACTIVE=prod
CONFIG_SERVER_URL=http://config-server:7071

# MySQL container/app credentials
CARRITO_MYSQL_ROOT_PASSWORD=root
CARRITO_MYSQL_DATABASE=db_carrito

# Spring datasource (used by carrito)
CARRITO_DB_HOST=mysql-carrito
CARRITO_DB_PORT=3306
CARRITO_DB_NAME=db_carrito
CARRITO_DB_USERNAME=root
CARRITO_DB_PASSWORD=root